{
	"name": "@ff-internal/sprint-planner",
	"version": "0.2.3",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "fluid-build . --task build",
		"build:compile": "fluid-build . --task compile",
		"build:esnext": "tsc --project ./tsconfig.json",
		"build:genver": "gen-version",
		"check:biome": "biome check .",
		"check:format": "npm run check:biome",
		"clean": "rimraf --glob dist \"**/*.tsbuildinfo\" \"**/*.build.log\"",
		"eslint": "eslint --quiet --format stylish src",
		"eslint:fix": "eslint --quiet --format stylish src --fix --fix-type problem,suggestion,layout",
		"eval": "node dist/eval/eval.js",
		"format": "npm run format:biome",
		"format:biome": "biome check . --write",
		"lint": "fluid-build . --task lint",
		"lint:fix": "fluid-build . --task eslint:fix --task format",
		"start": "start-server-and-test start:server 7070 start:client",
		"start:client": "webpack serve --open --env development",
		"start:server": "tinylicious",
		"test": "npm run test:jest",
		"test:jest": "jest --ci",
		"webpack": "webpack --env production",
		"preinstall": "node ../../../../scripts/only-pnpm.cjs"
	},
	"dependencies": {
		"@azure/identity": "^4.13.0",
		"@ff-internal/eval-app": "workspace:*",
		"@ff-internal/eval-framework": "workspace:*",
		"@fluidframework/react": "workspace:~",
		"@fluidframework/tinylicious-client": "workspace:~",
		"@fluidframework/tree": "workspace:~",
		"@fluidframework/tree-agent": "workspace:~",
		"fluid-framework": "workspace:~",
		"openai": "^4.73.0",
		"process": "^0.11.10",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "~2.4.5",
		"@fluid-tools/build-cli": "catalog:buildTools",
		"@fluidframework/build-common": "^2.0.3",
		"@fluidframework/build-tools": "catalog:buildTools",
		"@fluidframework/eslint-config-fluid": "catalog:eslint",
		"@types/jest": "29.5.3",
		"@types/node": "catalog:types",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.0",
		"css-loader": "^7.1.2",
		"eslint": "catalog:eslint",
		"html-webpack-plugin": "^5.6.0",
		"jest": "^29.6.2",
		"jest-junit": "^16.0.0",
		"jiti": "^2.6.1",
		"rimraf": "^6.1.3",
		"source-map-loader": "^5.0.0",
		"start-server-and-test": "^2.0.3",
		"style-loader": "^4.0.0",
		"tinylicious": "^7.0.0",
		"ts-jest": "^29.1.1",
		"ts-loader": "^9.5.1",
		"typescript": "~5.4.5",
		"webpack": "^5.94.0",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "~4.15.2"
	},
	"fluidBuild": {
		"tasks": {
			"build:esnext": [
				"build:genver"
			],
			"webpack": [
				"build:esnext"
			]
		}
	},
	"typeValidation": {
		"disabled": true
	}
}
