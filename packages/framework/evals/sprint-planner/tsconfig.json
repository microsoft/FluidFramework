{
	"extends": "../../../../common/build/build-common/tsconfig.node16.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node"],
		"skipLibCheck": true,
		"noUnusedLocals": false,
		"exactOptionalPropertyTypes": false,
		"noUncheckedIndexedAccess": false,
	},
	"include": ["src/**/*"],
	"exclude": ["src/test/**/*", "dist"],
}
