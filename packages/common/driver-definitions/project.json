{
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"targets": {
		"tsc": {
			"executor": "nx:run-commands",
			"options": {
				"command": "{workspaceRoot}/scripts/nx-clean-and-build.sh tsc",
				"cwd": "{projectRoot}"
			}
		},
		"build:esnext": {
			"executor": "nx:run-commands",
			"options": {
				"command": "{workspaceRoot}/scripts/nx-clean-and-build.sh build:esnext",
				"cwd": "{projectRoot}"
			}
		},
		"api": {
			"executor": "nx:noop"
		},
		"build": {
			"executor": "nx:noop"
		},
		"build:api-reports": {
			"executor": "nx:noop"
		},
		"build:compile": {
			"executor": "nx:noop"
		},
		"check:format": {
			"executor": "nx:noop"
		},
		"ci:build:api-reports": {
			"executor": "nx:noop"
		},
		"format": {
			"executor": "nx:noop"
		},
		"lint": {
			"executor": "nx:noop"
		},
		"lint:fix": {
			"executor": "nx:noop"
		}
	}
}
