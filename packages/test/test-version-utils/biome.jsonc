{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"overrides": [
		{
			// These files are created and edited by scripts (e.g. updateCompatVersions.ts).
			"includes": ["compat-workspaces/**/package.json", "compat-workspaces/versions.json"],
			"linter": { "enabled": false },
			"formatter": { "enabled": false }
		}
	]
}
