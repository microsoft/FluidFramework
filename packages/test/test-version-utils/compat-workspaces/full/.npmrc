# Ideally we'd use isolated node_modules here, but doing so is problematic.
# Specifically, we declare a root dependency on @fluidframework/local-driver in each compat workspace, which depends on some version of @fluidframework/server-local-server
# (which is versioned independently). test-version-utils currently loads the version of server-local-server transitively depended on by the driver layer in compat tests,
# and it expects this transitive dependency to be found directly under node_modules.
#
# There may be some other unknown issues with using isolated node_modules. AB#72053 tracks this work.
node-linker=hoisted
