{
	// Use Bundler over Node16 as the app itself targets the browser.
	// Tests and playwright.config.ts run under Node.js but are included here so ESLint
	// can type-check them. @types/node is added to types for this reason.
	"extends": "../../../common/build/build-common/tsconfig.bundler.json",
	"compilerOptions": {
		"outDir": "./lib",
		// After the upgrade to React 18 we're getting compilation issues from the .d.ts files of some fluentUi components.
		// Skipping lib check seems acceptable since this is just an example app.
		"skipLibCheck": true,
		"types": ["react", "react-dom", "node"],
		"exactOptionalPropertyTypes": false,
	},
	"include": ["src/**/*", "tests/**/*", "playwright.config.ts"],
}
