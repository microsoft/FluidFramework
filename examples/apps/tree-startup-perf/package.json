{
	"name": "@fluid-example/tree-startup-perf",
	"version": "2.93.0",
	"private": true,
	"description": "Minimal single-page app using @fluidframework/tree for startup performance testing.",
	"homepage": "https://fluidframework.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/FluidFramework.git",
		"directory": "examples/apps/tree-startup-perf"
	},
	"license": "MIT",
	"author": "Microsoft and contributors",
	"type": "module",
	"scripts": {
		"build": "fluid-build . --task build",
		"build:compile": "fluid-build . --task compile",
		"build:esnext": "tsc --project ./tsconfig.json",
		"check:biome": "biome check .",
		"check:format": "npm run check:biome",
		"clean": "rimraf --glob dist lib \"**/*.tsbuildinfo\" \"**/*.build.log\"",
		"eslint": "eslint --quiet --format stylish src",
		"eslint:fix": "eslint --quiet --format stylish src --fix --fix-type problem,suggestion,layout",
		"format": "npm run format:biome",
		"format:biome": "biome check . --write",
		"lint": "fluid-build . --task lint",
		"lint:fix": "fluid-build . --task eslint:fix --task format",
		"prepack": "npm run webpack",
		"lighthouse": "lhci autorun",
		"generate-ballast": "tsx scripts/generateBallast.ts",
		"sweep": "tsx scripts/sweep.ts",
		"start": "webpack serve",
		"webpack": "webpack --env production",
		"webpack:dev": "webpack --env development"
	},
	"dependencies": {
		"@fluidframework/tree": "workspace:~"
	},
	"devDependencies": {
		"@biomejs/biome": "~2.4.5",
		"@fluidframework/build-tools": "catalog:buildTools",
		"@fluidframework/eslint-config-fluid": "catalog:eslint",
		"@lhci/cli": "^0.15.1",
		"chrome-launcher": "^1.2.1",
		"eslint": "catalog:eslint",
		"html-webpack-plugin": "^5.6.0",
		"jiti": "^2.6.1",
		"lighthouse": "^12.6.1",
		"rimraf": "^6.1.3",
		"ts-loader": "^9.5.1",
		"tsx": "^4.21.0",
		"typescript": "~5.4.5",
		"webpack": "^5.94.0",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "~4.15.2"
	},
	"typeValidation": {
		"disabled": true
	}
}
