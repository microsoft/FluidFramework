{
	"name": "@fluid-example/inventory-app",
	"version": "2.101.0",
	"private": true,
	"description": "Minimal sample of SharedTree/React integration.",
	"homepage": "https://fluidframework.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/FluidFramework.git",
		"directory": "examples/data-objects/inventory-app"
	},
	"license": "MIT",
	"author": "Microsoft and contributors",
	"type": "module",
	"scripts": {
		"build": "fluid-build . --task build",
		"build:compile": "fluid-build . --task compile",
		"build:esnext": "tsc --project ./tsconfig.json",
		"build:test": "npm run build:test:esm",
		"build:test:esm": "tsc --project ./src/test/tsconfig.json",
		"check:biome": "biome check .",
		"check:format": "npm run check:biome",
		"clean": "rimraf --glob dist lib \"**/*.tsbuildinfo\" \"**/*.build.log\" nyc",
		"eslint": "eslint --quiet --format stylish src",
		"eslint:fix": "eslint --quiet --format stylish src --fix --fix-type problem,suggestion,layout",
		"format": "npm run format:biome",
		"format:biome": "biome check . --write",
		"lint": "fluid-build . --task lint",
		"lint:fix": "fluid-build . --task eslint:fix --task format",
		"prepack": "npm run webpack",
		"start": "npm run start:tinylicious",
		"start:azure": "start-server-and-test \"npx @fluidframework/azure-local-service\" 7071 \"webpack serve --config webpack.config.cjs --env FLUID_CLIENT=azure\"",
		"start:tinylicious": "start-server-and-test tinylicious 7070 \"webpack serve --config webpack.config.cjs\"",
		"test": "npm run test:mocha",
		"test:mocha": "npm run test:mocha:esm",
		"test:mocha:esm": "mocha",
		"webpack": "webpack --env production",
		"webpack:dev": "webpack --env development"
	},
	"dependencies": {
		"@fluidframework/azure-client": "workspace:~",
		"@fluidframework/react": "workspace:~",
		"@fluidframework/tinylicious-driver": "workspace:~",
		"fluid-framework": "workspace:~",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "~2.4.5",
		"@fluid-internal/mocha-test-setup": "workspace:~",
		"@fluidframework/build-common": "^2.0.3",
		"@fluidframework/build-tools": "catalog:buildTools",
		"@fluidframework/eslint-config-fluid": "catalog:eslint",
		"@testing-library/react": "^16.3.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "catalog:types",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.5",
		"assert": "^2.1.0",
		"eslint": "catalog:eslint",
		"eslint-plugin-react": "~7.37.5",
		"eslint-plugin-react-hooks": "~7.0.1",
		"global-jsdom": "^26.0.0",
		"html-webpack-plugin": "^5.6.0",
		"jiti": "^2.6.1",
		"jsdom": "^26.1.0",
		"mocha": "^11.7.5",
		"process": "^0.11.10",
		"rimraf": "^6.1.3",
		"source-map-loader": "^5.0.0",
		"start-server-and-test": "^2.0.3",
		"tinylicious": "^7.0.0",
		"ts-loader": "^9.5.1",
		"typescript": "~5.4.5",
		"webpack": "^5.94.0",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "~4.15.2",
		"webpack-merge": "^6.0.1"
	},
	"fluid": {
		"browser": {
			"umd": {
				"files": [
					"dist/main.bundle.js"
				],
				"library": "main"
			}
		}
	},
	"typeValidation": {
		"disabled": true
	}
}
