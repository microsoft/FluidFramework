{
	"name": "@fluid-example/tree-alpha",
	"version": "2.90.0",
	"private": true,
	"description": "SharedTree wrapper to support alpha expression declarations",
	"homepage": "https://fluidframework.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/FluidFramework.git",
		"directory": "examples/utils/cross-package-schema/tree-alpha"
	},
	"license": "MIT",
	"author": "Microsoft and contributors",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./index.d.ts",
				"default": "./index.js"
			}
		}
	},
	"scripts": {
		"check:biome": "biome check .",
		"check:format": "npm run check:biome",
		"clean": "rimraf --glob \"**/*.build.log\"",
		"eslint": "eslint --quiet --format stylish index.*",
		"eslint:fix": "eslint --quiet --format stylish index.* --fix --fix-type problem,suggestion,layout",
		"format": "npm run format:biome",
		"format:biome": "biome check . --write",
		"lint": "fluid-build . --task lint",
		"lint:fix": "fluid-build . --task eslint:fix --task format"
	},
	"peerDependencies": {
		"@fluidframework/tree": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "~1.9.3",
		"@fluid-tools/build-cli": "^0.63.0",
		"@fluidframework/build-common": "^2.0.3",
		"@fluidframework/build-tools": "^0.63.0",
		"@fluidframework/eslint-config-fluid": "workspace:~",
		"eslint": "~9.39.1",
		"jiti": "^2.6.1",
		"rimraf": "^6.1.3"
	},
	"typeValidation": {
		"disabled": true
	}
}
