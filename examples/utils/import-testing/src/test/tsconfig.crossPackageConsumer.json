{
	"extends": "./tsconfig.json",
	"include": ["./crossPackage/**/*"],
	"exclude": [],
	"compilerOptions": {
		// The base tsconfig sets skipLibCheck: false to validate declarations, but that
		// checks cross-package .d.ts output which has known broken import paths.
		// Override to true here so these cross-package consumer tests can compile.
		"skipLibCheck": true,
	},
	"references": [
		{
			"path": "../../tsconfig.crossPackage.bundler.json",
		},
		{
			"path": "../../tsconfig.crossPackage.node16.json",
		},
	],
}
