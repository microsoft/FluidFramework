{
	"extends": "../../../../common/build/build-common/tsconfig.node16.json",
	"exclude": ["dist", "lib", "node_modules"],
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./lib",
		"types": ["react", "node"],
		"exactOptionalPropertyTypes": false,
	},
	// Keep src-only here so the emitted layout (./lib/...) matches the package's
	// expected output paths. Playwright transpiles tests and playwright.config.ts
	// via its own TypeScript runner and doesn't need them in tsc's emit.
	"include": ["src/**/*"],
}
