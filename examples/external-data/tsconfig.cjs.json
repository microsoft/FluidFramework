{
	// This config must be used in a "type": "commonjs" environment. (Use fluid-tsc commonjs.)
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
	},
	// playwright.config.ts uses import.meta which isn't allowed in CommonJS output;
	// it's only consumed by Playwright's own runner and doesn't need a CJS build.
	"exclude": ["playwright.config.ts"],
}
