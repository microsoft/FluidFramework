{
	"extends": "../../../../common/build/build-common/tsconfig.base.json",
	"exclude": ["src/test/**/*"],
	"compilerOptions": {
		"downlevelIteration": true,
		"noUnusedLocals": false,
		"outDir": "./lib",
		"rootDir": "./src",
		// Types for 'node' are required by 'msgpackr', even though we avoid the
		// node-specific functionality at runtime.
		"types": ["node"],
		"noUncheckedIndexedAccess": false,
		"exactOptionalPropertyTypes": false,
		// Use "bundler" module resolution to allow for property-properties package.
		"module": "esnext",
		"moduleResolution": "bundler",
	},
	"include": ["src/**/*"],
}
