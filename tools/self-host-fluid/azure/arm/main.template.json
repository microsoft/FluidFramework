{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "acrName": {
      "type": "string",
      "defaultValue": "youracrname",
      "metadata": {
        "description": "Container registry name (globally unique)."
      }
    },
    "acrLocation": {
      "type": "string",
      "defaultValue": "eastus",
      "metadata": {
        "description": "Region for the container registry."
      }
    },
    "aksClusterName": {
      "type": "string",
      "defaultValue": "your-aks-cluster",
      "metadata": {
        "description": "AKS managed cluster name."
      }
    },
    "aksLocation": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Region for the AKS cluster and its MC_ node group."
      }
    },
    "kubernetesVersion": {
      "type": "string",
      "defaultValue": "1.35",
      "metadata": {
        "description": "Kubernetes control-plane version."
      }
    },
    "nodeVmSize": {
      "type": "string",
      "defaultValue": "Standard_D4as_v4",
      "metadata": {
        "description": "VM size for the system node pool."
      }
    },
    "nodeCount": {
      "type": "int",
      "defaultValue": 3,
      "metadata": {
        "description": "Node count for the system node pool."
      }
    },
    "dnsPrefix": {
      "type": "string",
      "defaultValue": "aks-cluster",
      "metadata": {
        "description": "AKS API server DNS prefix."
      }
    },
    "sshPublicKey": {
      "type": "string",
      "metadata": {
        "description": "SSH public key for Linux nodes (required; provide your own — no default for security)."
      }
    }
  },
  "resources": [
    {
      "apiVersion": "2026-01-01-preview",
      "location": "[parameters('acrLocation')]",
      "name": "[parameters('acrName')]",
      "properties": {
        "adminUserEnabled": true,
        "anonymousPullEnabled": false,
        "autoGeneratedDomainNameLabelScope": "Unsecure",
        "dataEndpointEnabled": false,
        "encryption": {
          "status": "disabled"
        },
        "endpointProtocol": "IPv4",
        "metadataSearch": "Disabled",
        "networkRuleBypassAllowedForTasks": false,
        "networkRuleBypassOptions": "AzureServices",
        "policies": {
          "azureADAuthenticationAsArmPolicy": {
            "status": "enabled"
          },
          "exportPolicy": {
            "status": "enabled"
          },
          "quarantinePolicy": {
            "status": "disabled"
          },
          "retentionPolicy": {
            "days": 7,
            "status": "disabled"
          },
          "softDeletePolicy": {
            "retentionDays": 7,
            "status": "disabled"
          },
          "trustPolicy": {
            "status": "disabled",
            "type": "Notary"
          }
        },
        "publicNetworkAccess": "Enabled",
        "regionalEndpoints": "Disabled",
        "roleAssignmentMode": "LegacyRegistryPermissions",
        "zoneRedundancy": "Disabled"
      },
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "type": "Microsoft.ContainerRegistry/registries"
    },
    {
      "apiVersion": "2026-04-02-preview",
      "identity": {
        "type": "SystemAssigned"
      },
      "kind": "Base",
      "location": "[parameters('aksLocation')]",
      "name": "[parameters('aksClusterName')]",
      "properties": {
        "addonProfiles": {
          "azurepolicy": {
            "enabled": true
          },
          "extensionManager": {
            "enabled": true
          }
        },
        "agentPoolProfiles": [
          {
            "count": "[parameters('nodeCount')]",
            "enableAutoScaling": false,
            "enableEncryptionAtHost": false,
            "enableFIPS": false,
            "enableNodePublicIP": false,
            "enableUltraSSD": false,
            "kubeletDiskType": "OS",
            "maxPods": 250,
            "mode": "System",
            "name": "nodepool1",
            "networkProfile": {},
            "orchestratorVersion": "[parameters('kubernetesVersion')]",
            "osDiskSizeGB": 128,
            "osDiskType": "Managed",
            "osSKU": "Ubuntu",
            "osType": "Linux",
            "scaleDownMode": "Delete",
            "securityProfile": {
              "enableSecureBoot": false,
              "enableVTPM": false,
              "sshAccess": "LocalUser"
            },
            "type": "VirtualMachineScaleSets",
            "upgradeSettings": {
              "maxSurge": "10%",
              "maxUnavailable": "0"
            },
            "upgradeStrategy": "Rolling",
            "vmSize": "[parameters('nodeVmSize')]",
            "workloadRuntime": "OCIContainer"
          }
        ],
        "autoUpgradeProfile": {
          "nodeOSUpgradeChannel": "NodeImage"
        },
        "bootstrapProfile": {
          "artifactSource": "Direct"
        },
        "disableLocalAccounts": false,
        "dnsPrefix": "[parameters('dnsPrefix')]",
        "enableFIPS": false,
        "enableRBAC": true,
        "healthMonitorProfile": {
          "enableContinuousControlPlaneAndAddonMonitor": false,
          "enableOnDemandMonitor": false
        },
        "hostedSystemProfile": {
          "enabled": false
        },
        "kubernetesVersion": "[parameters('kubernetesVersion')]",
        "linuxProfile": {
          "adminUsername": "azureuser",
          "ssh": {
            "publicKeys": [
              {
                "keyData": "[parameters('sshPublicKey')]"
              }
            ]
          }
        },
        "metricsProfile": {
          "costAnalysis": {
            "enabled": false
          }
        },
        "networkProfile": {
          "dnsServiceIP": "10.0.0.10",
          "ipFamilies": [
            "IPv4"
          ],
          "loadBalancerProfile": {
            "backendPoolType": "nodeIPConfiguration",
            "managedOutboundIPs": {
              "count": 1
            }
          },
          "loadBalancerSku": "standard",
          "networkDataplane": "azure",
          "networkPlugin": "azure",
          "networkPluginMode": "overlay",
          "networkPolicy": "none",
          "outboundType": "loadBalancer",
          "podCidr": "10.244.0.0/16",
          "podCidrs": [
            "10.244.0.0/16"
          ],
          "podLinkLocalAccess": "IMDS",
          "serviceCidr": "10.0.0.0/16",
          "serviceCidrs": [
            "10.0.0.0/16"
          ]
        },
        "nodeDisruptionProfile": {
          "nodeDisruptionPolicy": "Allow"
        },
        "nodeProvisioningProfile": {
          "mode": "Manual"
        },
        "nodeResourceGroup": "[concat('MC_', resourceGroup().name, '_', parameters('aksClusterName'), '_', parameters('aksLocation'))]",
        "oidcIssuerProfile": {
          "enabled": true
        },
        "securityProfile": {},
        "servicePrincipalProfile": {
          "clientId": "msi"
        },
        "storageProfile": {
          "diskCSIDriver": {
            "enabled": true
          },
          "fileCSIDriver": {
            "enabled": true
          },
          "snapshotController": {
            "enabled": true
          }
        },
        "supportPlan": "KubernetesOfficial",
        "workloadAutoScalerProfile": {}
      },
      "sku": {
        "name": "Base",
        "tier": "Free"
      },
      "type": "Microsoft.ContainerService/managedClusters"
    },
    {
      "apiVersion": "2026-01-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ],
      "name": "[concat(parameters('acrName'), '/_repositories_admin')]",
      "properties": {
        "actions": [
          "repositories/*/metadata/read",
          "repositories/*/metadata/write",
          "repositories/*/content/read",
          "repositories/*/content/write",
          "repositories/*/content/delete"
        ],
        "description": "Can perform all read, write and delete operations on the registry"
      },
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps"
    },
    {
      "apiVersion": "2026-01-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ],
      "name": "[concat(parameters('acrName'), '/_repositories_pull')]",
      "properties": {
        "actions": [
          "repositories/*/content/read"
        ],
        "description": "Can pull any repository of the registry"
      },
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps"
    },
    {
      "apiVersion": "2026-01-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ],
      "name": "[concat(parameters('acrName'), '/_repositories_pull_metadata_read')]",
      "properties": {
        "actions": [
          "repositories/*/content/read",
          "repositories/*/metadata/read"
        ],
        "description": "Can perform all read operations on the registry"
      },
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps"
    },
    {
      "apiVersion": "2026-01-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ],
      "name": "[concat(parameters('acrName'), '/_repositories_push')]",
      "properties": {
        "actions": [
          "repositories/*/content/read",
          "repositories/*/content/write"
        ],
        "description": "Can push to any repository of the registry"
      },
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps"
    },
    {
      "apiVersion": "2026-01-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ],
      "name": "[concat(parameters('acrName'), '/_repositories_push_metadata_write')]",
      "properties": {
        "actions": [
          "repositories/*/metadata/read",
          "repositories/*/metadata/write",
          "repositories/*/content/read",
          "repositories/*/content/write"
        ],
        "description": "Can perform all read and write operations on the registry"
      },
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps"
    },
    {
      "apiVersion": "2026-04-02-preview",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName'))]"
      ],
      "name": "[concat(parameters('aksClusterName'), '/nodepool1')]",
      "properties": {
        "count": "[parameters('nodeCount')]",
        "enableAutoScaling": false,
        "enableEncryptionAtHost": false,
        "enableFIPS": false,
        "enableNodePublicIP": false,
        "enableUltraSSD": false,
        "kubeletDiskType": "OS",
        "maxPods": 250,
        "mode": "System",
        "networkProfile": {},
        "orchestratorVersion": "[parameters('kubernetesVersion')]",
        "osDiskSizeGB": 128,
        "osDiskType": "Managed",
        "osSKU": "Ubuntu",
        "osType": "Linux",
        "scaleDownMode": "Delete",
        "securityProfile": {
          "enableSecureBoot": false,
          "enableVTPM": false,
          "sshAccess": "LocalUser"
        },
        "type": "VirtualMachineScaleSets",
        "upgradeSettings": {
          "maxSurge": "10%",
          "maxUnavailable": "0"
        },
        "upgradeStrategy": "Rolling",
        "vmSize": "[parameters('nodeVmSize')]",
        "workloadRuntime": "OCIContainer"
      },
      "type": "Microsoft.ContainerService/managedClusters/agentPools"
    }
  ],
  "variables": {}
}
