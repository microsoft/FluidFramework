{
	"name": "fluid-framework-docs",
	"version": "0.0.0",
	"private": true,
	"homepage": "https://fluidframework.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/FluidFramework.git",
		"directory": "docs"
	},
	"license": "MIT",
	"author": "Microsoft and contributors",
	"scripts": {
		"format": "npm run prettier:fix",
		"preinstall": "node ../scripts/only-pnpm.cjs",
		"lint": "concurrently npm:prettier npm:markdownlint",
		"lint:fix": "npm run prettier:fix && npm run markdownlint:fix",
		"markdownlint": "markdownlint-cli2 \"**/*.md\"",
		"markdownlint:fix": "markdownlint-cli2 --fix \"**/*.md\"",
		"prettier": "prettier --check . --cache --ignore-path ../.prettierignore",
		"prettier:fix": "prettier --write . --cache --ignore-path ../.prettierignore"
	},
	"devDependencies": {
		"concurrently": "^10.0.3",
		"markdownlint-cli2": "^0.22.0",
		"markdownlint-rule-relative-links": "^5.1.1",
		"prettier": "^3.3.3"
	},
	"packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
	"engines": {
		"node": ">=22.22.2"
	}
}
